# ───────────────────────────────────────────────────────────────────────────────
# Supabase Configuration
# ───────────────────────────────────────────────────────────────────────────────

# Project URL (found in Supabase Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Anon Key (found in Supabase Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key (Keep this secret! Used for admin tasks)
SUPABASE_SERVICE_ROLE_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# AI & External Services
# ───────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key (for Smart Insights and Chat)
GEMINI_API_KEY=

# OpenAI API Key (Backup for Gemini)
OPENAI_API_KEY=

# Finnhub API Key (for real-time stock prices)
FINNHUB_API_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# Localization & UI Settings
# ───────────────────────────────────────────────────────────────────────────────

# Default currency symbol (e.g., ₪)
NEXT_PUBLIC_CURRENCY_SYMBOL=₪

# Locale for date formatting (e.g., he-IL)
NEXT_PUBLIC_LOCALE=he-IL

# Partner names for UI display
NEXT_PUBLIC_PARTNER_1_NAME=
NEXT_PUBLIC_PARTNER_2_NAME=

# ───────────────────────────────────────────────────────────────────────────────
# App Settings
# ───────────────────────────────────────────────────────────────────────────────

# Base URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000
